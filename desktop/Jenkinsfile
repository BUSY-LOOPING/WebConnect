pipeline {
    agent none

    environment {
        GH_TOKEN = credentials('github-token')
    }

    stages {

        stage('Detect Changes & Bump Version') {
            agent {
                docker {
                    image 'node:20-bullseye'
                    
                }
            }
            steps {
                script {
                    def changedFiles = sh(
                        script: "git diff --name-only HEAD~1 HEAD",
                        returnStdout: true
                    ).trim()

                    echo "Changed files:\n${changedFiles}"

                    def hasDesktopChanges = changedFiles.split('\n').any {
                        it.startsWith('desktop/')
                    }

                    if (!hasDesktopChanges) {
                        echo "No changes in desktop/ — skipping."
                        currentBuild.result = 'NOT_BUILT'
                        error("Stopping: no desktop changes.")
                    }

                    def commitMsg = sh(
                        script: "git log -1 --pretty=%B",
                        returnStdout: true
                    ).trim().toLowerCase()

                    env.BUMP_TYPE = commitMsg.contains('[major]') ? 'major' : 'minor'
                    echo "Bump type: ${env.BUMP_TYPE}"

                    dir('desktop') {
                        def newVersion = sh(
                            script: "node scripts/bump-version.js ${env.BUMP_TYPE}",
                            returnStdout: true
                        ).trim()
                        env.APP_VERSION = newVersion
                        echo "New version: v${env.APP_VERSION}"
                    }

                    sh """
                        git config user.email "ci@jenkins"
                        git config user.name "Jenkins CI"
                        git add desktop/package.json
                        git commit -m "chore: bump version to v${env.APP_VERSION} [skip ci]"
                        git push https://${GH_TOKEN}@github.com/BUSY-LOOPING/WebConnect.git HEAD:main
                    """
                }
            }
        }

        // stage('Build Windows (.exe)') {
        //     agent { label 'windows' }  
        //     steps {
        //         dir('desktop') {
        //             bat 'npm ci'
        //             bat 'npm run build'
        //             bat 'npx electron-builder --win'
        //             stash includes: 'dist/*.exe', name: 'windows-build'
        //         }
        //     }
        // }

        stage('Build Linux (.AppImage)') {
            agent {
                docker {
                    image 'electronuserland/builder:wine'
                    args '--privileged'
                }
            }
            steps {
                withCredentials([file(credentialsId: 'webconnect-desktop-env', variable: 'SECURE_ENV')]) {
                    dir('desktop') {
                        sh "cp \$SECURE_ENV .env"
                        sh 'npm ci'
                        sh 'npm run build'
                        sh 'npx electron-builder --linux'
                        stash includes: 'dist/*.AppImage', name: 'linux-build'
                    }
                }
            }
        }

        stage('Release to GitHub') {
            agent {
                docker { image 'node:20-slim' }
            }
            steps {
                sh 'apt-get update && apt-get install -y gh ca-certificates'
                unstash 'linux-build'
                sh "echo \${GH_TOKEN} | gh auth login --with-token"
                sh """
                    gh release create v${env.APP_VERSION} \
                        dist/WebConnect-${env.APP_VERSION}.AppImage \
                        --title "Release v${env.APP_VERSION}" \
                        --notes "Bump type: ${env.BUMP_TYPE}" \
                        --repo BUSY-LOOPING/WebConnect
                """
            }
        }
    }

    post {
        success { echo "Released v${env.APP_VERSION}" }
        failure  { echo "Pipeline failed" }
    }
}